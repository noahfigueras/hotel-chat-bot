# Meta WhatsApp API
# Get this from https://developers.facebook.com/ → Your App → WhatsApp → API Setup
META_ACCESS_TOKEN=your_meta_access_token_here

# WhatsApp verify token (any random string you want to use)
VERIFY_TOKEN=your_verify_token_here

# Tavily API (get free key at https://tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000

# Hotels folder path (optional, defaults to ./hotels)
# HOTELS_PATH=/path/to/custom/hotels
